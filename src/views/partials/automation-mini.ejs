<div class="profile-mini-automation" data-automation-live-root data-automation-live-endpoint="/automation/live">
  <p><strong>Stored Login:</strong> <%= automation.hasStoredCredentials ? "Saved securely" : "Not saved yet" %></p>
  <p><strong>Enabled:</strong> <%= automation.enabled ? "Yes" : "No" %></p>
  <p><strong>Last Status:</strong> <%= automation.lastRunStatus || "idle" %></p>
  <p><strong>Last Success:</strong> <%= automation.lastSuccessAt || "Never" %></p>
  <p><strong>Next Run:</strong> <%= automation.nextRunAt || "Not scheduled" %></p>
  <% if (automation.lastFailureMessage) { %>
    <p class="error-text"><strong>Last Failure:</strong> <%= automation.lastFailureMessage %></p>
  <% } %>
  <p class="section-empty">
    Your CE Check-In login is stored on the backend and reused automatically whenever automation needs to sign in.
  </p>
  <% const snapshotMode = automation.hasCurrentRunSnapshot ? "current" : (automation.hasLastRunSnapshot ? "last" : ""); %>
  <div class="automation-visual" data-automation-live-visual <%= snapshotMode ? "" : "hidden" %>>
    <p><strong>Agent Visual:</strong></p>
    <img
      class="automation-visual-image"
      data-automation-live-image
      src="<%= snapshotMode ? `/automation/snapshot/${snapshotMode}?v=${encodeURIComponent(automation.lastRunAt || automation.lastSuccessAt || Date.now())}` : "" %>"
      alt="Automation progress preview"
    />
  </div>
  <p><strong>Agent Activity:</strong></p>
  <% const runLog = automation.currentRunLog && automation.currentRunLog.length > 0 ? automation.currentRunLog : automation.lastRunLog || []; %>
  <div data-automation-live-log>
    <% if (runLog.length === 0) { %>
      <p class="section-empty" data-automation-live-empty>No automation activity yet.</p>
    <% } else { %>
      <% runLog.forEach((entry) => { %>
        <p data-automation-live-entry><strong><%= entry.at %></strong> <%= entry.message %></p>
      <% }) %>
    <% } %>
  </div>
  <p class="section-empty" data-automation-live-status <%= automation.lastRunStatus === "running" ? "" : "hidden" %>>
    Live view is updating while the agent works.
  </p>
</div>
