<%
  const isGoogleConfigured =
    typeof googleConfigured !== "undefined" ? googleConfigured : false;
  const isGoogleConnected =
    typeof googleConnected !== "undefined" ? googleConnected : false;
  const isTestProfileActive =
    typeof testProfileActive !== "undefined" ? testProfileActive : false;
  const activeTestProfile =
    typeof testProfile !== "undefined" && testProfile ? testProfile : null;
  const safeCurrentUser =
    typeof currentUser !== "undefined" && currentUser ? currentUser : null;
  const safeAuthRequired =
    typeof authRequired !== "undefined" ? Boolean(authRequired) : true;
  const userSeed =
    safeCurrentUser &&
    (safeCurrentUser.displayName || safeCurrentUser.email || "U");
  const userInitial = userSeed ? userSeed.trim().charAt(0).toUpperCase() : "U";
  const pageKey = typeof page !== "undefined" ? String(page || "") : "";
  const showMobileHeader = [
    "appointment-form",
    "appointment-view",
    "settings",
    "settings-history",
    "calendar",
    "agent",
    "checkin"
  ].includes(pageKey);
  const mobileHeaderDate = new Date().toLocaleDateString("en-US", {
    weekday: "long",
    month: "short",
    day: "numeric"
  });
%>
<!DOCTYPE html>
<html lang="en" data-theme="vaultDark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %> | Appointment Vault</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/public/style.css" />
    <link rel="stylesheet" href="/public/app.css" />
    <script src="https://unpkg.com/htmx.org@2.0.4" defer></script>
    <script src="/public/ui.js" defer></script>
    <script src="/public/ui-activity.js" defer></script>
    <script src="/public/ui-error-boundary.js" defer></script>
  </head>
  <body class="<%= typeof page !== 'undefined' && page ? `page-${page}` : '' %>">
    <div class="app-shell">
      <input id="sidebar-toggle" type="checkbox" class="sidebar-toggle-input" />
      <aside class="app-sidebar">
        <div class="sidebar-brand">
          <span class="sidebar-logo">S</span>
          <span class="sidebar-title">Appointment Vault</span>
        </div>
        <nav class="menu sidebar-nav" aria-label="Primary">
          <a class="nav-pill" data-nav-key="dashboard" href="/dashboard">
            <span class="nav-icon">DB</span>
            <span>Dashboard</span>
          </a>
          <a class="nav-pill" data-nav-key="new" href="/appointments">
            <span class="nav-icon">APT</span>
            <span>Appointments</span>
          </a>
          <a class="nav-pill" data-nav-key="settings" href="/settings">
            <span class="nav-icon">SET</span>
            <span>Settings</span>
          </a>
        </nav>

        <% if (safeAuthRequired && safeCurrentUser) { %>
          <div class="sidebar-profile">
            <div class="sidebar-avatar" aria-hidden="true"><%= userInitial %></div>
            <div class="sidebar-profile-meta">
              <span class="sidebar-profile-name"><%= safeCurrentUser.displayName || safeCurrentUser.email || "User" %></span>
              <% if (safeCurrentUser.email) { %>
                <span class="sidebar-profile-email"><%= safeCurrentUser.email %></span>
              <% } %>
            </div>
          </div>
          <form class="sidebar-logout" action="/auth/logout" method="POST">
            <button class="button glass-button button-secondary w-full" type="submit">Sign Out</button>
          </form>
        <% } %>
      </aside>
      <label for="sidebar-toggle" class="sidebar-overlay" aria-label="Close sidebar"></label>

      <div class="app-main">
        <header class="app-topbar">
          <div class="topbar-left">
            <label for="sidebar-toggle" class="sidebar-toggle" aria-label="Toggle sidebar">
              <svg class="sidebar-toggle-icon" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              </svg>
            </label>
            <form class="topbar-search" action="/appointments" method="GET">
              <label class="input input-bordered topbar-search-input">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z" />
                </svg>
                <input type="text" name="title" placeholder="Search appointments" />
              </label>
            </form>
          </div>
          <div class="topbar-right">
            <a class="button glass-button button-primary-blue" href="/appointments#quick-add">Create draft</a>
            <button type="button" class="icon-button" aria-label="Notifications">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.4-1.4A2 2 0 0118 14.17V11a6 6 0 10-12 0v3.17a2 2 0 01-.6 1.43L4 17h5m6 0a3 3 0 11-6 0h6z" />
              </svg>
            </button>
            <button type="button" class="icon-button" aria-label="Quick actions">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6" />
              </svg>
            </button>
            <button type="button" class="icon-button" data-theme-toggle aria-pressed="false" aria-label="Toggle dark mode">🌙</button>
            <% if (safeCurrentUser) { %>
              <div class="profile-hub" data-profile-hub>
                <button
                  type="button"
                  class="avatar-pill profile-trigger"
                  data-profile-trigger
                  aria-expanded="false"
                  aria-haspopup="true"
                  aria-label="Open profile controls"
                >
                  <%= userInitial %>
                </button>
                <div class="profile-control-pill" data-profile-pill hidden>
                  <button
                    type="button"
                    class="profile-control-button"
                    data-profile-open="calendar"
                    data-profile-src="/calendar"
                    data-profile-title="Calendar"
                    data-profile-meta="View your calendar panel"
                  >
                    Calendar
                  </button>
                  <button
                    type="button"
                    class="profile-control-button"
                    data-profile-open="checkin"
                    data-profile-src="https://www.cecheckin.com/client/account/signin"
                    data-profile-title="Check-In"
                    data-profile-meta="Open your check-in panel"
                  >
                    Check-In
                  </button>
                </div>
              </div>
            <% } %>
          </div>
        </header>

        <% if (safeCurrentUser) { %>
          <div class="hero-modal hero-sheet-modal profile-mini-modal" data-profile-mini-modal hidden>
            <div class="hero-modal-backdrop" data-profile-mini-close></div>
            <div class="hero-modal-card profile-mini-card" role="dialog" aria-modal="true" aria-label="Quick panel">
              <button class="hero-modal-close" type="button" data-profile-mini-close aria-label="Close">✕</button>
              <div class="hero-modal-header">
                <div>
                  <p class="hero-modal-eyebrow">Quick Panel</p>
                  <h3 class="hero-modal-title" data-profile-mini-title>Panel</h3>
                  <p class="hero-modal-meta" data-profile-mini-meta>Open a quick view.</p>
                </div>
              </div>
              <div class="hero-modal-body profile-mini-body">
                <div class="hero-modal-actions">
                  <a
                    class="hero-button"
                    data-profile-mini-open-full
                    href="/calendar"
                  >
                    Open Calendar Page
                  </a>
                  <a
                    class="hero-button hero-open-button"
                    data-profile-mini-open-external
                    href="https://calendar.google.com/calendar/u/0/r"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Open Google Calendar
                  </a>
                </div>
                <div class="profile-mini-content-card">
                  <p class="profile-mini-content" data-profile-mini-content>
                    Open your panel with the actions above.
                  </p>
                </div>
              </div>
            </div>
          </div>
          <script>
            window.addEventListener("DOMContentLoaded", () => {
              const hubs = Array.from(document.querySelectorAll("[data-profile-hub]"));
              const modal = document.querySelector("[data-profile-mini-modal]");
              if (hubs.length === 0 || !modal) return;

              const titleEl = modal.querySelector("[data-profile-mini-title]");
              const metaEl = modal.querySelector("[data-profile-mini-meta]");
              const contentEl = modal.querySelector("[data-profile-mini-content]");
              const openFullEl = modal.querySelector("[data-profile-mini-open-full]");
              const openExternalEl = modal.querySelector("[data-profile-mini-open-external]");
              const closeButtons = Array.from(modal.querySelectorAll("[data-profile-mini-close]"));

              const closeAllPills = () => {
                hubs.forEach((hub) => {
                  const trigger = hub.querySelector("[data-profile-trigger]");
                  const pill = hub.querySelector("[data-profile-pill]");
                  hub.classList.remove("is-open");
                  if (trigger) trigger.setAttribute("aria-expanded", "false");
                  if (pill) pill.hidden = true;
                });
              };

              const closeMini = () => {
                modal.classList.remove("is-open");
                setTimeout(() => {
                  modal.hidden = true;
                }, 220);
                document.body.classList.remove("modal-open");
              };

              const openMini = (button) => {
                const panel = String(button.getAttribute("data-profile-open") || "").trim().toLowerCase();
                const src = String(button.getAttribute("data-profile-src") || "/calendar");
                const title = String(button.getAttribute("data-profile-title") || "Panel");
                const meta = String(button.getAttribute("data-profile-meta") || "");
                if (titleEl) titleEl.textContent = title;
                if (metaEl) metaEl.textContent = meta;
                if (panel === "checkin") {
                  if (contentEl) {
                    contentEl.textContent =
                      "Open CE Check-In directly to continue your sign-in and updates.";
                  }
                  if (openFullEl) {
                    openFullEl.textContent = "Open Check-In Page";
                    openFullEl.setAttribute("href", "/checkin");
                  }
                  if (openExternalEl) {
                    openExternalEl.hidden = false;
                    openExternalEl.textContent = "Open CE Check-In";
                    openExternalEl.setAttribute("href", src);
                  }
                } else {
                  if (contentEl) {
                    contentEl.textContent =
                      "Google Calendar may block embedded sign-in in mini panels. Use the buttons below for reliable access.";
                  }
                  if (openFullEl) {
                    openFullEl.textContent = "Open Calendar Page";
                    openFullEl.setAttribute("href", "/calendar");
                  }
                  if (openExternalEl) {
                    openExternalEl.hidden = false;
                    openExternalEl.textContent = "Open Google Calendar";
                    openExternalEl.setAttribute("href", "https://calendar.google.com/calendar/u/0/r");
                  }
                }
                modal.hidden = false;
                document.body.classList.add("modal-open");
                requestAnimationFrame(() => modal.classList.add("is-open"));
              };

              hubs.forEach((hub) => {
                const trigger = hub.querySelector("[data-profile-trigger]");
                const pill = hub.querySelector("[data-profile-pill]");
                if (!trigger || !pill) return;
                trigger.addEventListener("click", (event) => {
                  event.stopPropagation();
                  const isOpen = hub.classList.contains("is-open");
                  closeAllPills();
                  if (!isOpen) {
                    hub.classList.add("is-open");
                    trigger.setAttribute("aria-expanded", "true");
                    pill.hidden = false;
                  }
                });
              });

              document.querySelectorAll("[data-profile-open]").forEach((button) => {
                button.addEventListener("click", () => {
                  closeAllPills();
                  openMini(button);
                });
              });

              closeButtons.forEach((button) => {
                button.addEventListener("click", closeMini);
              });

              document.addEventListener("click", (event) => {
                if (!hubs.some((hub) => hub.contains(event.target))) {
                  closeAllPills();
                }
              });

              document.addEventListener("keydown", (event) => {
                if (event.key === "Escape") {
                  closeAllPills();
                  closeMini();
                }
              });
            });
          </script>
        <% } %>

        <main class="app-content">
          <% if (showMobileHeader) { %>
            <header class="mobile-page-header">
              <div>
                <p class="mobile-fitness-title"><%= title %></p>
                <p class="mobile-fitness-date"><%= mobileHeaderDate %></p>
              </div>
              <% if (safeCurrentUser) { %>
                <div class="profile-hub" data-profile-hub>
                  <button
                    type="button"
                    class="mobile-avatar profile-trigger"
                    data-profile-trigger
                    aria-expanded="false"
                    aria-haspopup="true"
                    aria-label="Open profile controls"
                  >
                    <%= userInitial %>
                  </button>
                  <div class="profile-control-pill" data-profile-pill hidden>
                    <button
                      type="button"
                      class="profile-control-button"
                      data-profile-open="calendar"
                      data-profile-src="/calendar"
                      data-profile-title="Calendar"
                      data-profile-meta="View your calendar panel"
                    >
                      Calendar
                    </button>
                    <button
                      type="button"
                      class="profile-control-button"
                      data-profile-open="checkin"
                      data-profile-src="/checkin"
                      data-profile-title="Check-In"
                      data-profile-meta="Open your check-in panel"
                    >
                      Check-In
                    </button>
                  </div>
                </div>
              <% } else { %>
                <div class="mobile-avatar"><%= userInitial %></div>
              <% } %>
            </header>

            <nav class="mobile-pill-nav">
              <a class="pill <%= pageKey === 'dashboard' ? 'pill-active' : '' %>" href="/dashboard">Dashboard</a>
              <a class="pill <%= pageKey.includes('appointment') ? 'pill-active' : '' %>" href="/appointments">Appointments</a>
              <a class="pill <%= pageKey.startsWith('settings') ? 'pill-active' : '' %>" href="/settings">Settings</a>
            </nav>
          <% } %>
